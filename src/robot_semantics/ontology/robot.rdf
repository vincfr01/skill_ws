    <!-- http://www.semanticweb.org/lunzm/ontologies/2026/1/untitled-ontology-22#hasComponent -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/lunzm/ontologies/2026/1/untitled-ontology-22#hasComponent">

    <!-- http://www.semanticweb.org/lunzm/ontologies/2026/1/untitled-ontology-22#SixAxisRobot -->

    <owl:Class rdf:about="http://www.semanticweb.org/lunzm/ontologies/2026/1/untitled-ontology-22#SixAxisRobot">
